# Copy to .env and fill in values

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK — go to Firebase Console → Project Settings → Service accounts
# → Generate new private key → download JSON → paste the ENTIRE JSON as one line
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"awaken",...}

# Random 64-char secret — generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-64-char-random-secret
JWT_EXPIRE_HOURS=168
